# Capture & Vault API authentication
# A default key is baked into both the Android app (DEFAULT_VAULT_KEY in VoiceChatViewModel.kt)
# and the server (capture_api.py). Both sides work out of the box with no config needed.
# Set this variable to rotate the key — update JARVIS_CAPTURE_KEY here AND DEFAULT_VAULT_KEY
# in the Android source, then cut a new release.
JARVIS_CAPTURE_KEY=0WBpWVdLsieaJPpTI7JEjKBZZMd2G-9WWZM2Iiq_wMo

# Optional vault override (defaults to /home/lordmuffin/Notes/00 Inbox/Voice Notes)
# VAULT_INBOX=/home/lordmuffin/Notes/00 Inbox/Voice Notes

# Optional Whisper model override (defaults to small.en)
# WHISPER_MODEL=small.en
