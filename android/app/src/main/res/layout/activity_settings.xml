<?xml version="1.0" encoding="utf-8"?>
<!-- Root is FrameLayout so the FAB floats over the ScrollView at all scroll positions -->
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/jv_bg">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="24dp"
            android:paddingBottom="96dp">

            <!-- ── Metro Stats ──────────────────────────────────────────── -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Metro"
                android:textColor="@color/jv_text2"
                android:textSize="11sp"
                android:textAllCaps="true"
                android:letterSpacing="0.08"
                android:layout_marginBottom="8dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:background="@color/jv_surface"
                android:padding="12dp">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="center">
                    <TextView
                        android:id="@+id/tv_stat_last_words"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="—"
                        android:textColor="@color/jv_text"
                        android:textSize="22sp"
                        android:textStyle="bold" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="last words"
                        android:textColor="@color/jv_text2"
                        android:textSize="10sp" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="center">
                    <TextView
                        android:id="@+id/tv_stat_last_wpm"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="—"
                        android:textColor="@color/jv_accent"
                        android:textSize="22sp"
                        android:textStyle="bold" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="last wpm"
                        android:textColor="@color/jv_text2"
                        android:textSize="10sp" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="center">
                    <TextView
                        android:id="@+id/tv_stat_total_words"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0"
                        android:textColor="@color/jv_text"
                        android:textSize="22sp"
                        android:textStyle="bold" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="total words"
                        android:textColor="@color/jv_text2"
                        android:textSize="10sp" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="center">
                    <TextView
                        android:id="@+id/tv_stat_avg_wpm"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0"
                        android:textColor="@color/jv_accent"
                        android:textSize="22sp"
                        android:textStyle="bold" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="avg wpm"
                        android:textColor="@color/jv_text2"
                        android:textSize="10sp" />
                </LinearLayout>

            </LinearLayout>

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="@color/jv_surface2"
                android:layout_marginTop="20dp"
                android:layout_marginBottom="20dp" />

            <!-- ── STT Model ─────────────────────────────────────────────── -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Speech Recognition"
                android:textColor="@color/jv_text2"
                android:textSize="11sp"
                android:textAllCaps="true"
                android:letterSpacing="0.08"
                android:layout_marginBottom="8dp" />

            <Button
                android:id="@+id/btn_open_stt_model_manager"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="STT Model"
                android:backgroundTint="@color/jv_surface2"
                android:textColor="@color/jv_text"
                android:gravity="start|center_vertical"
                android:paddingHorizontal="16dp"
                android:layout_marginBottom="4dp" />

            <TextView
                android:id="@+id/tv_active_stt_model"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="No model downloaded"
                android:textColor="@color/jv_text2"
                android:textSize="12sp"
                android:paddingHorizontal="4dp"
                android:layout_marginBottom="12dp" />

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="@color/jv_surface2"
                android:layout_marginBottom="20dp" />

            <!-- ── LLM Model ────────────────────────────────────────────── -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="LLM Enhancement"
                android:textColor="@color/jv_text2"
                android:textSize="11sp"
                android:textAllCaps="true"
                android:letterSpacing="0.08"
                android:layout_marginBottom="8dp" />

            <Button
                android:id="@+id/btn_open_model_manager"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="LLM Model"
                android:backgroundTint="@color/jv_surface2"
                android:textColor="@color/jv_text"
                android:gravity="start|center_vertical"
                android:paddingHorizontal="16dp"
                android:layout_marginBottom="4dp" />

            <TextView
                android:id="@+id/tv_active_llm_model"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Enhancement: Off"
                android:textColor="@color/jv_text2"
                android:textSize="12sp"
                android:paddingHorizontal="4dp"
                android:layout_marginBottom="12dp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="HuggingFace Token"
                android:textColor="@color/jv_text2"
                android:textSize="11sp"
                android:layout_marginBottom="4dp" />

            <EditText
                android:id="@+id/et_hf_token"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="hf_xxxxxxxxxxxxxxxx"
                android:inputType="textPassword"
                android:textColor="@color/jv_text"
                android:textColorHint="@color/jv_text2"
                android:background="@drawable/permission_card_bg"
                android:padding="12dp"
                android:textSize="13sp"
                android:fontFamily="monospace"
                android:layout_marginBottom="4dp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Required for Gemma model downloads. Accept the license at huggingface.co/litert-community first."
                android:textColor="@color/jv_text2"
                android:textSize="11sp"
                android:layout_marginBottom="16dp" />

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="@color/jv_surface2"
                android:layout_marginBottom="20dp" />

            <!-- ── Features ─────────────────────────────────────────────── -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Features"
                android:textColor="@color/jv_text2"
                android:textSize="11sp"
                android:textAllCaps="true"
                android:letterSpacing="0.08"
                android:layout_marginBottom="8dp" />

            <Button
                android:id="@+id/btn_open_history"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Dictation History"
                android:backgroundTint="@color/jv_surface2"
                android:textColor="@color/jv_text"
                android:gravity="start|center_vertical"
                android:paddingHorizontal="16dp"
                android:layout_marginBottom="8dp" />

            <Button
                android:id="@+id/btn_open_dictionary"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Custom Dictionary"
                android:backgroundTint="@color/jv_surface2"
                android:textColor="@color/jv_text"
                android:gravity="start|center_vertical"
                android:paddingHorizontal="16dp"
                android:layout_marginBottom="8dp" />

            <Button
                android:id="@+id/btn_open_debug_log"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Debug Log"
                android:backgroundTint="@color/jv_surface2"
                android:textColor="@color/jv_text2"
                android:gravity="start|center_vertical"
                android:paddingHorizontal="16dp" />

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="@color/jv_surface2"
                android:layout_marginTop="20dp"
                android:layout_marginBottom="20dp" />

            <!-- ── Data Storage ─────────────────────────────────────────── -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Data Storage"
                android:textColor="@color/jv_text2"
                android:textSize="11sp"
                android:textAllCaps="true"
                android:letterSpacing="0.08"
                android:layout_marginBottom="8dp" />

            <TextView
                android:id="@+id/tv_storage_location"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="@color/jv_text2"
                android:textSize="12sp"
                android:paddingHorizontal="4dp"
                android:layout_marginBottom="8dp" />

            <Button
                android:id="@+id/btn_grant_storage"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Grant All Files Access"
                android:backgroundTint="@color/jv_surface2"
                android:textColor="@color/jv_accent"
                android:gravity="start|center_vertical"
                android:paddingHorizontal="16dp"
                android:layout_marginBottom="4dp"
                android:visibility="gone" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Grant once to store history and logs in /sdcard/Documents/JarvisVoice/. Existing data migrates automatically."
                android:textColor="@color/jv_text2"
                android:textSize="11sp"
                android:paddingHorizontal="4dp"
                android:layout_marginBottom="16dp" />

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="@color/jv_surface2"
                android:layout_marginBottom="20dp" />

            <!-- ── Notifications ────────────────────────────────────────── -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Notifications"
                android:textColor="@color/jv_text2"
                android:textSize="11sp"
                android:textAllCaps="true"
                android:letterSpacing="0.08"
                android:layout_marginBottom="8dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingTop="8dp"
                android:paddingBottom="8dp">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Clipboard notification"
                        android:textColor="@color/jv_text"
                        android:textSize="16sp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Show in tray when dictation is copied to clipboard"
                        android:textColor="@color/jv_text2"
                        android:textSize="12sp"
                        android:layout_marginTop="2dp" />

                </LinearLayout>

                <androidx.appcompat.widget.SwitchCompat
                    android:id="@+id/switch_clipboard_notify"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content" />

            </LinearLayout>

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="@color/jv_surface2"
                android:layout_marginTop="16dp"
                android:layout_marginBottom="20dp" />

            <!-- ── STT Backend ──────────────────────────────────────────── -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="STT Backend"
                android:textColor="@color/jv_text2"
                android:textSize="11sp"
                android:textAllCaps="true"
                android:letterSpacing="0.08"
                android:layout_marginBottom="8dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingTop="8dp"
                android:paddingBottom="8dp">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="On-device STT (Offline)"
                        android:textColor="@color/jv_text"
                        android:textSize="16sp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Uses local Whisper model, no internet required"
                        android:textColor="@color/jv_text2"
                        android:textSize="12sp"
                        android:layout_marginTop="2dp" />

                </LinearLayout>

                <androidx.appcompat.widget.SwitchCompat
                    android:id="@+id/switch_offline_stt"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content" />

            </LinearLayout>

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="@color/jv_surface2"
                android:layout_marginTop="16dp"
                android:layout_marginBottom="20dp" />

            <!-- ── Vault Folder ───────────────────────────────────────────── -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Vault Capture"
                android:textColor="@color/jv_text2"
                android:textSize="11sp"
                android:textAllCaps="true"
                android:letterSpacing="0.08"
                android:layout_marginBottom="8dp" />

            <TextView
                android:id="@+id/tv_vault_folder"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textSize="12sp"
                android:paddingHorizontal="4dp"
                android:layout_marginBottom="8dp" />

            <Button
                android:id="@+id/btn_pick_vault_folder"
                android:layout_width="match_parent"
                android:layout_height="44dp"
                android:text="Pick Vault Folder"
                android:backgroundTint="@color/jv_surface2"
                android:textColor="@color/jv_text2"
                android:gravity="start|center_vertical"
                android:paddingHorizontal="16dp"
                android:layout_marginBottom="4dp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Pick any local folder — captures go to YYYY-MM-DD.md inside it. Works great pointed at a Syncthing-synced vault folder."
                android:textColor="@color/jv_text2"
                android:textSize="11sp"
                android:paddingHorizontal="4dp" />

        </LinearLayout>
    </ScrollView>

    <!-- Floating record button — always visible regardless of scroll position -->
    <Button
        android:id="@+id/fab_vault"
        android:layout_width="60dp"
        android:layout_height="60dp"
        android:layout_gravity="bottom|end"
        android:layout_marginEnd="20dp"
        android:layout_marginBottom="20dp"
        android:background="@drawable/fab_bg"
        android:text="🎙"
        android:textSize="24sp"
        android:textColor="@color/jv_bg"
        android:elevation="6dp"
        android:stateListAnimator="@null"
        android:contentDescription="Record to Vault" />

</FrameLayout>
