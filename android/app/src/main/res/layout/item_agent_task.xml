<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@color/jv_surface"
    android:layout_marginStart="8dp"
    android:layout_marginEnd="8dp"
    android:layout_marginBottom="6dp"
    android:padding="12dp"
    android:clickable="true"
    android:focusable="true"
    android:foreground="?attr/selectableItemBackground">

    <!-- Header: name + status badge + delete -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <!-- Status dot -->
        <TextView
            android:id="@+id/tv_status_dot"
            android:layout_width="10dp"
            android:layout_height="10dp"
            android:background="@drawable/status_dot"
            android:layout_marginEnd="8dp" />

        <!-- Task name -->
        <TextView
            android:id="@+id/tv_task_name"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:textColor="@color/jv_text"
            android:textSize="14sp"
            android:textStyle="bold"
            android:maxLines="1"
            android:ellipsize="end" />

        <!-- Delete button -->
        <Button
            android:id="@+id/btn_task_delete"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:text="✕"
            android:textSize="12sp"
            android:backgroundTint="@color/jv_surface2"
            android:textColor="@color/jv_text2"
            android:stateListAnimator="@null"
            android:padding="0dp" />

    </LinearLayout>

    <!-- Model chip + status text + elapsed -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginTop="4dp">

        <TextView
            android:id="@+id/tv_task_model"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="@color/jv_accent"
            android:textSize="10sp"
            android:background="@color/jv_surface2"
            android:paddingStart="6dp"
            android:paddingEnd="6dp"
            android:paddingTop="2dp"
            android:paddingBottom="2dp"
            android:layout_marginEnd="8dp" />

        <TextView
            android:id="@+id/tv_task_status"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:textColor="@color/jv_text2"
            android:textSize="11sp" />

        <TextView
            android:id="@+id/tv_task_elapsed"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="@color/jv_text2"
            android:textSize="11sp" />

    </LinearLayout>

    <!-- Output preview -->
    <TextView
        android:id="@+id/tv_task_output"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textColor="@color/jv_text"
        android:textSize="12sp"
        android:layout_marginTop="6dp"
        android:maxLines="3"
        android:ellipsize="end"
        android:visibility="gone" />

    <!-- Expand/collapse label + Reply button row -->
    <LinearLayout
        android:id="@+id/ll_task_actions"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginTop="6dp"
        android:visibility="gone">

        <TextView
            android:id="@+id/tv_expand"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Show output ▼"
            android:textColor="@color/jv_accent"
            android:textSize="11sp" />

        <Button
            android:id="@+id/btn_reply"
            android:layout_width="wrap_content"
            android:layout_height="28dp"
            android:text="↩ Reply"
            android:textSize="11sp"
            android:textAllCaps="false"
            android:paddingStart="10dp"
            android:paddingEnd="10dp"
            android:layout_marginEnd="2dp"
            android:backgroundTint="@color/jv_surface2"
            android:textColor="@color/jv_accent"
            android:stateListAnimator="@null" />

    </LinearLayout>

</LinearLayout>
