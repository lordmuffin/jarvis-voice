<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@color/jv_surface">

    <!-- Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="16dp"
        android:paddingEnd="12dp">

        <TextView
            android:id="@+id/tv_convo_title"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:textColor="@color/jv_text"
            android:textSize="15sp"
            android:textStyle="bold"
            android:maxLines="1"
            android:ellipsize="end" />

        <TextView
            android:id="@+id/tv_convo_model"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="@color/jv_accent"
            android:textSize="11sp"
            android:layout_marginEnd="8dp" />

    </LinearLayout>

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="@color/jv_surface2" />

    <!-- Conversation message list -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rv_convo"
        android:layout_width="match_parent"
        android:layout_height="340dp"
        android:overScrollMode="never"
        android:clipToPadding="false"
        android:paddingStart="12dp"
        android:paddingEnd="12dp"
        android:paddingTop="8dp"
        android:paddingBottom="8dp" />

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="@color/jv_surface2" />

    <!-- Reply input row -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="bottom"
        android:padding="10dp">

        <EditText
            android:id="@+id/et_reply"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:minLines="1"
            android:maxLines="4"
            android:background="@drawable/pill_background_dim"
            android:hint="Follow up…"
            android:textColorHint="@color/jv_text2"
            android:textColor="@color/jv_text"
            android:textSize="14sp"
            android:paddingStart="14dp"
            android:paddingEnd="14dp"
            android:paddingTop="10dp"
            android:paddingBottom="10dp"
            android:inputType="textMultiLine|textCapSentences"
            android:gravity="top"
            android:layout_marginEnd="8dp" />

        <Button
            android:id="@+id/btn_send_reply"
            android:layout_width="52dp"
            android:layout_height="52dp"
            android:text="▶"
            android:textSize="16sp"
            android:background="@drawable/pill_background_accent"
            android:textColor="@color/jv_bg"
            android:stateListAnimator="@null"
            android:layout_gravity="bottom" />

    </LinearLayout>

</LinearLayout>
