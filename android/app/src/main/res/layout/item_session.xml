<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="12dp"
    android:background="@color/jv_surface"
    android:foreground="?attr/selectableItemBackground"
    android:clickable="true"
    android:focusable="true"
    android:layout_marginBottom="4dp">

    <!-- Time + stats + expand chevron -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <TextView
            android:id="@+id/tv_session_time"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:textColor="@color/jv_text2"
            android:textSize="11sp" />

        <TextView
            android:id="@+id/tv_session_stats"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="@color/jv_accent"
            android:textSize="11sp"
            android:layout_marginEnd="8dp" />

        <TextView
            android:id="@+id/tv_expand_chevron"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="▼"
            android:textColor="@color/jv_text2"
            android:textSize="10sp" />

    </LinearLayout>

    <!-- Dual-pass section: shown only when LLM enhancement ran (raw ≠ final) -->
    <LinearLayout
        android:id="@+id/layout_dual_pass"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:visibility="gone">

        <TextView
            android:id="@+id/tv_whisper_label"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:text="WHISPER"
            android:textColor="@color/jv_text2"
            android:textSize="9sp"
            android:letterSpacing="0.1"
            android:textAllCaps="true" />

        <TextView
            android:id="@+id/tv_raw_transcript"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="@color/jv_text2"
            android:textSize="13sp"
            android:maxLines="2"
            android:ellipsize="end"
            android:layout_marginTop="1dp" />

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginTop="6dp"
            android:layout_marginBottom="2dp"
            android:background="@color/jv_surface2" />

        <TextView
            android:id="@+id/tv_enhanced_label"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="ENHANCED"
            android:textColor="@color/jv_accent"
            android:textSize="9sp"
            android:letterSpacing="0.1"
            android:textAllCaps="true"
            android:layout_marginBottom="1dp" />

    </LinearLayout>

    <!-- Final transcript — always visible; maxLines toggled in adapter -->
    <TextView
        android:id="@+id/tv_session_transcript"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textColor="@color/jv_text"
        android:textSize="14sp"
        android:layout_marginTop="4dp"
        android:maxLines="2"
        android:ellipsize="end" />

    <!-- Expanded action row — GONE until item is tapped -->
    <LinearLayout
        android:id="@+id/layout_expanded_actions"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginTop="10dp"
        android:visibility="gone">

        <!-- Copy the final (enhanced) transcript -->
        <Button
            android:id="@+id/btn_copy_final"
            android:layout_width="0dp"
            android:layout_height="36dp"
            android:layout_weight="1"
            android:text="Copy"
            android:textSize="12sp"
            android:backgroundTint="@color/jv_surface2"
            android:textColor="@color/jv_text"
            android:layout_marginEnd="6dp" />

        <!-- Only visible when LLM ran: copy the raw Whisper transcript -->
        <Button
            android:id="@+id/btn_copy_raw"
            android:layout_width="0dp"
            android:layout_height="36dp"
            android:layout_weight="1"
            android:text="Copy Whisper"
            android:textSize="12sp"
            android:backgroundTint="@color/jv_surface2"
            android:textColor="@color/jv_text2"
            android:visibility="gone" />

    </LinearLayout>

</LinearLayout>
