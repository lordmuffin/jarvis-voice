<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/jv_bg">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Replace spoken words automatically. Left column: what you say. Right column: what gets typed."
        android:textColor="@color/jv_text2"
        android:textSize="13sp"
        android:padding="16dp" />

    <Button
        android:id="@+id/btn_add_entry"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="+ Add word substitution"
        android:backgroundTint="@color/jv_accent"
        android:textColor="@color/jv_text"
        android:layout_marginHorizontal="16dp"
        android:layout_marginBottom="8dp" />

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rv_dict"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:padding="8dp"
        android:clipToPadding="false" />

</LinearLayout>
