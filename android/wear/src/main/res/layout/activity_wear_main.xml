<?xml version="1.0" encoding="utf-8"?>
<androidx.wear.widget.BoxInsetLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#111418"
    app:boxedEdges="all">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:gravity="center"
        android:padding="12dp">

        <!-- Response text from last synced capture -->
        <TextView
            android:id="@+id/tv_response"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:gravity="center"
            android:textColor="#B0B8C8"
            android:textSize="12sp"
            android:ellipsize="end"
            android:maxLines="4"
            android:text="Tap to capture" />

        <!-- Sync status badge -->
        <TextView
            android:id="@+id/tv_sync_status"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="8dp"
            android:textColor="#6B7280"
            android:textSize="10sp"
            android:text="" />

        <!-- Record button -->
        <Button
            android:id="@+id/btn_record"
            android:layout_width="72dp"
            android:layout_height="72dp"
            android:text="🎙"
            android:textSize="28sp"
            android:background="@drawable/btn_record_bg"
            android:stateListAnimator="@null" />

        <!-- Recording timer -->
        <TextView
            android:id="@+id/tv_timer"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:textColor="#E5424D"
            android:textSize="11sp"
            android:visibility="invisible"
            android:text="0:00" />

        <!-- Settings link -->
        <TextView
            android:id="@+id/tv_settings"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:text="⚙"
            android:textColor="#4B5563"
            android:textSize="14sp"
            android:padding="6dp" />

    </LinearLayout>

</androidx.wear.widget.BoxInsetLayout>
