<?xml version="1.0" encoding="utf-8"?>
<androidx.wear.widget.BoxInsetLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#111418"
    app:boxedEdges="all">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="12dp"
            android:gravity="center_horizontal">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Jarvis Wear"
                android:textColor="#E5E7EB"
                android:textSize="14sp"
                android:gravity="center"
                android:layout_marginBottom="12dp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="API Key"
                android:textColor="#6B7280"
                android:textSize="10sp" />

            <EditText
                android:id="@+id/et_api_key"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="textPassword"
                android:textColor="#E5E7EB"
                android:textSize="11sp"
                android:hint="X-Jarvis-Key"
                android:textColorHint="#4B5563"
                android:background="#1E2530"
                android:padding="6dp"
                android:layout_marginBottom="10dp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Server URL"
                android:textColor="#6B7280"
                android:textSize="10sp" />

            <EditText
                android:id="@+id/et_server_url"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="textUri"
                android:textColor="#E5E7EB"
                android:textSize="11sp"
                android:hint="https://kai.apj.dev"
                android:textColorHint="#4B5563"
                android:background="#1E2530"
                android:padding="6dp"
                android:layout_marginBottom="14dp" />

            <Button
                android:id="@+id/btn_save"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Save"
                android:textSize="12sp"
                android:backgroundTint="#3B82F6" />

        </LinearLayout>
    </ScrollView>

</androidx.wear.widget.BoxInsetLayout>
